{
  "sourceLanguage": "en",
  "strings": {
    "About": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このアプリについて"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "关于"
          }
        }
      }
    },
    "About 0.7–1 GB. Wi-Fi recommended. After download it runs entirely offline.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "約0.7〜1 GBです。Wi-Fiを推奨します。ダウンロード後は完全にオフラインで動作します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "约 0.7–1 GB，建议使用 Wi-Fi。下载后可完全离线运行。"
          }
        }
      }
    },
    "Accurate model": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "高精度モデル"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "高精度模型"
          }
        }
      }
    },
    "Add Replacement": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "置換ルールを追加"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加替换规则"
          }
        }
      }
    },
    "After download, no network is needed for recognition.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ダウンロード後の音声認識にネットワークは不要です。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "下载后，语音识别无需网络。"
          }
        }
      }
    },
    "App Language": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アプリの言語"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "App 语言"
          }
        }
      }
    },
    "Appearance": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "外観"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "外观"
          }
        }
      }
    },
    "Apple On-Device Speech": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple オンデバイス音声認識"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple 设备端语音识别"
          }
        }
      }
    },
    "Apple Speech": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple 音声認識"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple 语音识别"
          }
        }
      }
    },
    "Apple Speech gives you live text. Download Qwen3-ASR when you want a more accurate offline final pass.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple音声認識でリアルタイム表示し、より正確なオフライン最終結果が必要な場合はQwen3-ASRをダウンロードできます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple 语音识别提供实时文字；需要更准确的离线最终结果时，可下载 Qwen3-ASR。"
          }
        }
      }
    },
    "Apple final": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple 最終結果"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple 最终结果"
          }
        }
      }
    },
    "Apple live preview": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple リアルタイムプレビュー"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple 实时预览"
          }
        }
      }
    },
    "Apple live · Qwen accurate final": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple リアルタイム・Qwen 高精度最終結果"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple 实时 · Qwen 高精度最终结果"
          }
        }
      }
    },
    "Apple on-device recognition": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple オンデバイス音声認識"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple 设备端语音识别"
          }
        }
      }
    },
    "Audio always stays on this device": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "音声は常にこのデバイス内に保存されます"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "音频始终只留在此设备"
          }
        }
      }
    },
    "Audio and transcripts stay on this device": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "音声と文字起こしはこのデバイス内に保存されます"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "音频和转写内容仅保存在此设备"
          }
        }
      }
    },
    "Audio saved · transcript unavailable": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "音声を保存しました・文字起こしは利用できません"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "音频已保存 · 暂无转写"
          }
        }
      }
    },
    "Audio stays on this device. Transcript text can sync through your private iCloud account.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "音声はこのデバイス内に留まり、文字起こしだけをプライベートなiCloudアカウントで同期できます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "音频只留在此设备；转写文字可通过你的私有 iCloud 账户同步。"
          }
        }
      }
    },
    "Cancel": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "キャンセル"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "取消"
          }
        }
      }
    },
    "Capture short thoughts or longer voice notes.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "短いアイデアから長めの音声メモまで記録できます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "记录简短想法或较长的语音笔记。"
          }
        }
      }
    },
    "Choose Audio or Video": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "音声またはビデオを選択"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择音频或视频"
          }
        }
      }
    },
    "Choose a file, or drop one here on iPad. Audio is processed on this device and is never saved by OneVoice.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ファイルを選ぶか、iPadではここにドロップできます。音声はデバイス上で処理され、OneVoiceには保存されません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择文件，或在 iPad 上拖放到这里。音频会在设备端处理，OneVoice 不会保存音频。"
          }
        }
      }
    },
    "Clean Blue": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クリーンブルー"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "清透蓝"
          }
        }
      }
    },
    "Color theme": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カラーテーマ"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "配色主题"
          }
        }
      }
    },
    "Copied and saved": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コピーして保存しました"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已复制并保存"
          }
        }
      }
    },
    "Copy": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コピー"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "复制"
          }
        }
      }
    },
    "Copy or share the transcript into any app.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "文字起こしを任意のアプリにコピーまたは共有できます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将转写结果复制或分享到任意 App。"
          }
        }
      }
    },
    "Correct names and specialist vocabulary.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "名前や専門用語を正しく置換します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "修正姓名和专业词汇。"
          }
        }
      }
    },
    "Creating final transcript": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最終文字起こしを作成中"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "正在生成最终转写"
          }
        }
      }
    },
    "Crisp, bright, and utility-first.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "明るくシャープで、実用性を重視します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "清爽明亮，专注实用。"
          }
        }
      }
    },
    "Dark": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ダーク"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "深色"
          }
        }
