    "English (US)": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "英語（米国）"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "英语（美国）"
          }
        }
      }
    },
    "Example: “one voice” → “OneVoice”. Replacements are applied locally to every final transcript.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "例：「one voice」→「OneVoice」。置換はすべての最終文字起こしにローカルで適用されます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "示例：“one voice” → “OneVoice”。替换规则会在本地应用到每条最终转写。"
          }
        }
      }
    },
    "Fast Live, Accurate Final": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リアルタイムは高速、最終結果は高精度"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "实时快速，最终准确"
          }
        }
      }
    },
    "Fast feedback with system on-device speech.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "システムのオンデバイス音声認識ですばやく確認できます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通过系统设备端语音识别快速获得反馈。"
          }
        }
      }
    },
