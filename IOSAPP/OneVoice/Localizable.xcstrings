    "Not installed": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "未インストール"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未安装"
          }
        }
      }
