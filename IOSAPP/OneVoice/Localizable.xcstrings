    "English": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "英語"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "英语"
          }
        }
      }
