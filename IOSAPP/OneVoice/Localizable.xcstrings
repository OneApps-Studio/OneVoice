      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デバイス上で仕上げています…"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "正在设备端完成处理…"
          }
        }
      }
