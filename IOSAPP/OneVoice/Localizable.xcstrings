    "Keep searchable voice notes, teach OneVoice your vocabulary, and paste the result anywhere.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "検索できる音声メモを保存し、用語を登録して、結果をどこにでも貼り付けられます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "保存可搜索的语音笔记，教会 OneVoice 你的词汇，并将结果粘贴到任何地方。"
          }
        }
      }
